  def password; end

  # The password used with the encryption codec to encrypt or decrypt the file
  # data for an entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#518
  def password=(_arg0); end

  # The raw, possibly compressed and/or encrypted file data for an entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#520
  def raw_data; end

  # The raw, possibly compressed and/or encrypted file data for an entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#520
  def raw_data=(_arg0); end

  # Returns false.
  #
  # @return [Boolean]
  #
  # source://archive-zip//lib/archive/zip/entry.rb#545
  def symlink?; end

  # The user ID of the owner of this entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#500
  def uid; end

  # The user ID of the owner of this entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#500
  def uid=(_arg0); end

  # The path for this entry in the ZIP archive.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#494
  def zip_path; end

  # Sets the path in the archive for this entry to _zip_path_ after passing it
  # through Archive::Zip::Entry.expand_path and ensuring that the result is
  # not empty.
