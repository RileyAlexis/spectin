# Archive::Zip::Entry::Symlink represents a symlink entry withing a Zip
# archive.
#
# source://archive-zip//lib/archive/zip/entry.rb#897
class Archive::Zip::Entry::Symlink
  include ::Archive::Zip::Entry

  # Extracts this entry.
