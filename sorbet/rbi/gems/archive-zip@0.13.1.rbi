  def ftype; end

  # Returns the link target for this entry.
  #
  # Raises Archive::Zip::EntryError if decoding the link target from an
  # archive is required but fails.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#920
  def link_target; end

  # Sets the link target for this entry.  As a side effect, the raw_data
  # attribute is set to +nil+.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#947
  def link_target=(link_target); end

  # Overridden in order to ensure that the proper mode bits are set for a
  # symlink.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#912
  def mode=(mode); end

  # Returns +true+.
  #
  # @return [Boolean]
  #
  # source://archive-zip//lib/archive/zip/entry.rb#906
  def symlink?; end

  private

  # Write the link target to _io_ as the file data for the entry.
  #
  # source://archive-zip//lib/archive/zip/entry.rb#1011
  def dump_file_data(io); end
end

