# instances of Time.
#
# source://archive-zip//lib/archive/zip/dos_time.rb#6
class Archive::Zip::DOSTime
  include ::Comparable

  # Creates a new instance of DOSTime.  _dos_time_ is a 4 byte String or
  # unsigned number (Integer) representing an MS-DOS time structure where:
  # Bits 0-4::   2 second increments (0-29)
  # Bits 5-10::  minutes (0-59)
  # Bits 11-15:: hours (0-24)
  # Bits 16-20:: day (1-31)
  # Bits 21-24:: month (1-12)
  # Bits 25-31:: four digit year minus 1980 (0-119)
  #
  # If _dos_time_ is ommitted or +nil+, a new instance is created based on the
  # current time.
  #
  # @return [DOSTime] a new instance of DOSTime
  #
  # source://archive-zip//lib/archive/zip/dos_time.rb#20
  def initialize(time = T.unsafe(nil)); end

  # Returns 1 if _other_ is a time earlier than this one, 0 if _other_ is the
  # same time, and -1 if _other_ is a later time.
  #
  # @raise [ArgumentError]
  #
  # source://archive-zip//lib/archive/zip/dos_time.rb#39
  def <=>(other); end

  # Returns 1 if _other_ is a time earlier than this one, 0 if _other_ is the
  # same time, and -1 if _other_ is a later time.
  #
  # @raise [ArgumentError]
  #
  # source://archive-zip//lib/archive/zip/dos_time.rb#35
  def cmp(other); end

  # Returns the time value of this object as an integer representing the DOS
  # time structure.
  #
  # source://archive-zip//lib/archive/zip/dos_time.rb#43
  def to_i; end

  # Returns a Time instance which is equivalent to the time represented by
