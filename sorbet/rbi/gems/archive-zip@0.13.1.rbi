  # either a symlink or hard link target which may be stored in the variable
  # data section of this object.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#82
  def link_target; end

  # Takes a string containing the path to a file which is either a symlink or
  # a hardlink target and stores it in the variable data section of this
  # object.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#89
  def link_target=(link_target); end

  # This method signature is part of the interface contract expected by
  # Archive::Zip::Entry for extra field objects.
  #
  # Merges the attributes of _other_ into this object and returns +self+.
  #
  # Raises ArgumentError if _other_ is not the same class as this object.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#99
  def merge(other); end

  # A Time object representing the last modified time for an entry.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#60
  def mtime; end

  # A Time object representing the last modified time for an entry.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#60
  def mtime=(_arg0); end

  # An integer representing the user ownership for an entry.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#62
  def uid; end

  # An integer representing the user ownership for an entry.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#62
  def uid=(_arg0); end

  protected

  # Returns the value of attribute data.
  #
  # source://archive-zip//lib/archive/zip/extra_field/unix.rb#138
  def data; end

  class << self
    # This method signature is part of the interface contract expected by
    # Archive::Zip::Entry for extra field objects.
    #
    # Parses _data_ which is expected to be a String formatted according to
    # the official ZIP specification.
    #
    # Raises Archive::Zip::ExtraFieldError if _data_ contains invalid data.
    #
    # source://archive-zip//lib/archive/zip/extra_field/unix.rb#30
    def parse_central(data); end

    # This method signature is part of the interface contract expected by
    # Archive::Zip::Entry for extra field objects.
    #
    # Parses _data_ which is expected to be a String formatted according to
    # the official ZIP specification.
    #
    # Raises Archive::Zip::ExtraFieldError if _data_ contains invalid data.
    #
    # source://archive-zip//lib/archive/zip/extra_field/unix.rb#37
    def parse_local(data); end
  end
end

# The identifier reserved for this extra field type.
#
# source://archive-zip//lib/archive/zip/extra_field/unix.rb#17
Archive::Zip::ExtraField::Unix::ID = T.let(T.unsafe(nil), Integer)

# Archive::Zip::ExtraFieldError is raised when there is an error while
# processing an extra field in a ZIP archive entry.
#
# source://archive-zip//lib/archive/zip/error.rb#14
class Archive::Zip::ExtraFieldError < ::Archive::Zip::Error; end

# Archive::Zip::IOError is raised in various places where either an IOError is
# raised or an operation on an Archive::Zip object is disallowed because of
# the state of the object.
#
# source://archive-zip//lib/archive/zip/error.rb#19
class Archive::Zip::IOError < ::Archive::Zip::Error; end

# The lead-in marker for a local file record.
#
# source://archive-zip//lib/archive/zip.rb#40
Archive::Zip::LFH_SIGNATURE = T.let(T.unsafe(nil), String)

# Archive::Zip::UnzipError is raised when attempting to extract an archive
# fails but no more exact error class exists for reporting the error.
#
# source://archive-zip//lib/archive/zip/error.rb#23
class Archive::Zip::UnzipError < ::Archive::Zip::Error; end

# The lead-in marker for the ZIP64 end of central directory locator record.
#
# source://archive-zip//lib/archive/zip.rb#36
Archive::Zip::Z64EOCDL_SIGNATURE = T.let(T.unsafe(nil), String)

# The lead-in marker for the ZIP64 end of central directory record.
#
# source://archive-zip//lib/archive/zip.rb#34
Archive::Zip::Z64EOCD_SIGNATURE = T.let(T.unsafe(nil), String)

# IOExtensions provides convenience wrappers for certain IO functionality.
#
# source://archive-zip//lib/archive/support/ioextensions.rb#4
module IOExtensions
  class << self
    # Reads and returns exactly _length_ bytes from _io_ using the read method on
    # _io_.  If there is insufficient data available, an EOFError is raised.
    #
    # source://archive-zip//lib/archive/support/ioextensions.rb#7
    def read_exactly(io, length); end
  end
end

# IOWindow represents an IO object which wraps another one allowing read access
# to a subset of the data within the stream.
#
# source://archive-zip//lib/archive/support/iowindow.rb#7
class IOWindow < ::IO::LikeHelpers::DelegatedIO
  # Creates a new instance of this class using _delegate_ as the data source and
  # where _window_position_ and _window_size_ define the location and size of
  # data window respectively.
  #
  # _delegate_ must be opened for reading and must be seekable.
  # _window_position_ must be an integer greater than or equal to 0.
  # _window_size_ must be an integer greater than or equal to 0.
  #
  # @raise [ArgumentError]
  # @return [IOWindow] a new instance of IOWindow
  #
  # source://archive-zip//lib/archive/support/iowindow.rb#15
  def initialize(delegate, window_position, window_size, autoclose: T.unsafe(nil)); end

  # @raise [EOFError]
  #
  # source://archive-zip//lib/archive/support/iowindow.rb#28
  def read(length, buffer: T.unsafe(nil), buffer_offset: T.unsafe(nil)); end

  # source://archive-zip//lib/archive/support/iowindow.rb#44
  def seek(amount, whence = T.unsafe(nil)); end
end

# This extends StringIO to include additional methods required by the io-like
# library to wrap IO objects.
#
# source://archive-zip//lib/archive/support/stringio.rb#8
class StringIO
  include ::Enumerable

  # @return [Boolean]
  #
  # source://archive-zip//lib/archive/support/stringio.rb#17
  def nonblock?; end

  # source://archive-zip//lib/archive/support/stringio.rb#10
  def sysseek(offset, whence = T.unsafe(nil)); end

  # source://archive-zip//lib/archive/support/stringio.rb#23
  def wait(*args); end
end
